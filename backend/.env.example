# ==========================================
# 服务配置
# ==========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# ==========================================
# 数据库配置
# ==========================================
# 开发环境请替换为你的实际 PostgreSQL 凭证
# 测试环境使用默认 DATABASE_URL，可以不填
DATABASE_URL="postgresql://postgres:你的密码@localhost:5432/finance_manager?schema=public"

# ==========================================
# CORS配置
# ==========================================
# 开发环境建议设为 http://localhost:5173
# 生产环境设为前端实际地址
# 设为 * 允许所有来源（但会禁用凭证）
CORS_ORIGIN=*

# ==========================================
# 日志配置
# ==========================================
# 日志级别: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ==========================================
# AI 配置（智能助手功能）
# ==========================================
# 当前支持的 Provider:
#   deepseek   - DeepSeek（推荐，免费额度高，响应快）
#   openai     - OpenAI / 硅基流动 / 其他 OpenAI 兼容 API
#   hunyuan    - 腾讯云混元
#   disabled   - 禁用 AI 功能
AI_PROVIDER=disabled

# ---------- DeepSeek 配置 ----------
# 获取地址: https://platform.deepseek.com/
# 注册送额度，性价比高
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ---------- OpenAI / 硅基流动 配置 ----------
# 硅基流动注册: https://siliconflow.cn/
# 也适用于 Azure OpenAI 等兼容服务
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_MODEL=gpt-4o-mini

# ---------- 腾讯云混元 配置 ----------
# 获取地址: https://console.cloud.tencent.com/cam/capi
# TENCENT_SECRET_ID=你的SecretId
# TENCENT_SECRET_KEY=你的SecretKey
# HUNYUAN_MODEL=hunyuan-turbo
